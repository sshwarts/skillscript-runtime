# HttpWebhookAgentConnector — example .env config.
# Copy to .env in your project root + fill in your real URLs.
#
# Agent map: nested JSON, keys are agent_id strings, values are per-agent config.
# `url` is required; `wake_url` + `status_url` are optional.
#
# The agent_id key is what skill authors write in their skills:
#   notify(agent="agent-slack", message="...")  → POSTs to the "agent-slack" url
#
# Use any naming convention that fits your deployment:
#   - "agent-{channel}" — channel-as-agent-id (this example uses this)
#   - "{role}-{channel}" — role/person + channel (e.g., "oncall-slack")
#   - Whatever your team understands
#
# Three deployment models the wire format supports:
#   Model A: one URL per agent_id (separate ports / hosts / paths)
#   Model B: single URL, router receiver dispatches on `agent_id` field in body
#   Model C: variable-driven channel selection in the skill — notify(agent="agent-${CHANNEL}", ...)
HTTP_WEBHOOK_AGENTS={"agent-slack":{"url":"http://localhost:3200/webhook/slack","wake_url":"http://localhost:3200/wake/slack"},"agent-whatsapp":{"url":"http://localhost:3200/webhook/whatsapp"}}

# Per-request timeout (ms). Covers total request duration:
# connect + send + receive + body parse.
HTTP_WEBHOOK_TIMEOUT_MS=5000

# OPTIONAL: bearer-token auth. When set, every outbound POST includes
# `Authorization: <value>`. Use for substrate endpoints behind a shared secret.
# Skip when using HMAC (use HTTP_WEBHOOK_HMAC_SECRET instead).
HTTP_WEBHOOK_AUTH=

# OPTIONAL: HMAC-SHA256 body signing. When set, every outbound POST includes
# `X-Signature: sha256=<hex>`. Receiver MUST validate against the RAW HTTP
# body BEFORE parsing JSON (common foot-gun: re-encoding parsed objects
# produces a different hash from key-ordering / whitespace drift).
HTTP_WEBHOOK_HMAC_SECRET=
