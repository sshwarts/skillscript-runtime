{
  "name": "skillscript-runtime",
  "version": "0.13.3",
  "description": "Runtime, compiler, lint, CLI, and dashboard for Skillscript — a small declarative language for authoring agent workflows.",
  "license": "MIT",
  "author": "Scott Shwarts <scotts@pobox.com>",
  "homepage": "https://github.com/sshwarts/skillscript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sshwarts/skillscript.git"
  },
  "bugs": {
    "url": "https://github.com/sshwarts/skillscript/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./connectors": {
      "types": "./dist/connectors/index.d.ts",
      "import": "./dist/connectors/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./trace": {
      "types": "./dist/trace.d.ts",
      "import": "./dist/trace.js"
    },
    "./metrics": {
      "types": "./dist/metrics.d.ts",
      "import": "./dist/metrics.js"
    },
    "./scheduler": {
      "types": "./dist/scheduler.d.ts",
      "import": "./dist/scheduler.js"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "skillfile": "./dist/cli.js"
  },
  "files": [
    "dist",
    "scaffold",
    "examples",
    "docs/*.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-dashboard-assets.mjs && node scripts/check-published-paths.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "loc-check": "node scripts/loc-ceiling.mjs",
    "lint": "tsc --noEmit && vitest run",
    "prepublishOnly": "pnpm run build && pnpm run loc-check && pnpm run test"
  },
  "keywords": [
    "skillscript",
    "agent",
    "agent-workflow",
    "dsl",
    "declarative",
    "workflow",
    "llm",
    "mcp",
    "model-context-protocol"
  ],
  "dependencies": {
    "cron-parser": "^4.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@11.0.8",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
